---
import Button from "../components/ui/Button.astro";
import Layout from "../layouts/Layout.astro";

const services = [
  {
    title: "Domestic Wiring and Rewires",
    detail:
      "Full and partial rewires, kitchen and extension wiring, and clean upgrades that futureproof your home.",
    highlight: "No hidden extras",
  },
  {
    title: "Fault Finding and Emergency Repairs",
    detail:
      "Rapid diagnosis for tripping circuits, dead sockets, and unsafe electrics with clear fixes you can trust.",
    highlight: "Fast local response",
  },
  {
    title: "Inspection, Testing and Certificates",
    detail:
      "EICRs, landlord checks, and compliance testing delivered with straightforward reports and practical advice.",
    highlight: "Certified and compliant",
  },
  {
    title: "Commercial Install and Maintenance",
    detail:
      "Lighting, power distribution, planned maintenance, and out-of-hours support for offices and retail spaces.",
    highlight: "Minimal downtime",
  },
];

const benefits = [
  "Detailed quote before work starts",
  "Clean, respectful work on every visit",
  "Daily progress updates on larger jobs",
  "Certification supplied at handover",
];

const process = [
  {
    step: "01",
    title: "Quick Scope Call",
    description: "Tell us what is happening. We ask focused questions and set the right next step.",
  },
  {
    step: "02",
    title: "Fixed Plan and Quote",
    description: "You get a clear plan, timescale, and price breakdown before tools come out.",
  },
  {
    step: "03",
    title: "Precise Delivery",
    description: "Work is completed to regulation, tested, and signed off with tidy handover notes.",
  },
];

const faqs = [
  {
    question: "Can you help if another electrician has started and left the job incomplete?",
    answer:
      "Yes. We can assess existing work, identify safety issues, and give you a practical completion plan with transparent pricing.",
  },
  {
    question: "Do you work around business opening hours?",
    answer:
      "Yes. For commercial clients we can schedule early, late, or weekend slots to keep disruption to a minimum.",
  },
  {
    question: "How do I know what work is essential versus optional?",
    answer:
      "We split recommendations into urgent, recommended, and optional improvements so you can make an informed decision.",
  },
  {
    question: "Will I receive compliance paperwork after the job?",
    answer:
      "Yes. Where certification is required, we provide the relevant documentation at completion.",
  },
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Tec Electrical",
  description: "Domestic and commercial electrical services in Leicester and surrounding areas.",
  telephone: "+447000000000",
  email: "hello@tec-electrical.co.uk",
  areaServed: "Leicester",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Leicester",
    addressCountry: "GB",
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "08:00",
      closes: "18:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Saturday"],
      opens: "09:00",
      closes: "14:00",
    },
  ],
  url: "https://tec.dotwall.co.uk/",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://tec.dotwall.co.uk/",
    },
  ],
};
---

<Layout
  pageTitle="Electricians in Leicester for Homes and Business | Tec Electrical"
  pageDescription="Tec Electrical provides fault finding, rewires, testing, and commercial electrical support in Leicester with clear quotes and safe certified work."
  schemas={[localBusinessSchema, faqSchema, breadcrumbSchema]}
>
  <section class="relative overflow-hidden bg-slate-950 py-20 text-white md:py-28">
    <div class="absolute inset-0 opacity-55 [background:radial-gradient(circle_at_15%_20%,rgba(59,130,246,0.35),transparent_38%),radial-gradient(circle_at_90%_8%,rgba(251,191,36,0.25),transparent_30%),linear-gradient(120deg,#020617_10%,#0f172a_55%,#172554_100%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.05)_1px,transparent_1px)] bg-[size:48px_48px] [mask-image:radial-gradient(ellipse_at_center,black_42%,transparent_80%)]"></div>

    <div class="relative mx-auto grid w-full max-w-6xl gap-10 px-4 sm:px-6 lg:grid-cols-[1.15fr_0.85fr] lg:px-8">
      <div class="max-w-2xl">
        <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-blue-300/30 bg-blue-500/10 px-4 py-2 text-xs font-semibold uppercase tracking-wider text-blue-100">
          <span class="inline-block h-2 w-2 rounded-full bg-emerald-300"></span>
          Trusted Electrical Team in Leicester
        </p>
        <h1 class="text-balance text-4xl font-bold leading-tight md:text-6xl">
          Electrical work done once, done right, and built to last.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-200">
          We combine technical precision with clear communication. You get safe installs, practical advice, and a smooth
          experience from first call to final certificate.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href="#contact">Book My Free Quote</Button>
          <Button href="#process" variant="secondary">How We Work</Button>
        </div>
        <div class="mt-8 grid gap-3 text-sm sm:grid-cols-3">
          <p class="rounded-xl border border-white/15 bg-white/5 px-4 py-3">Fully insured and qualified</p>
          <p class="rounded-xl border border-white/15 bg-white/5 px-4 py-3">Transparent pricing model</p>
          <p class="rounded-xl border border-white/15 bg-white/5 px-4 py-3">Domestic and commercial</p>
        </div>
      </div>

      <div class="rounded-3xl border border-white/20 bg-white/8 p-6 shadow-2xl backdrop-blur">
        <h2 class="text-sm font-semibold uppercase tracking-[0.16em] text-blue-100">Live Project Snapshot</h2>
        <div class="mt-5 space-y-4">
          <article class="rounded-xl border border-emerald-300/40 bg-emerald-400/10 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-emerald-200">Emergency Fault</p>
            <p class="mt-2 text-lg font-semibold">Ring main failure in family home</p>
            <p class="mt-2 text-sm text-emerald-100">Diagnosed, isolated, and restored safely in one visit.</p>
          </article>
          <article class="rounded-xl border border-blue-300/35 bg-blue-500/10 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-blue-100">Commercial Upgrade</p>
            <p class="mt-2 text-lg font-semibold">Retail lighting retrofit</p>
            <p class="mt-2 text-sm text-blue-100">Lower energy usage with brighter, cleaner output for customers.</p>
          </article>
          <article class="rounded-xl border border-amber-300/35 bg-amber-300/10 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-100">Certification</p>
            <p class="mt-2 text-lg font-semibold">Landlord EICR package</p>
            <p class="mt-2 text-sm text-amber-50">Clear report, priority fixes, and completed compliance paperwork.</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200/70 bg-white py-10">
    <div class="mx-auto grid w-full max-w-6xl gap-4 px-4 text-sm font-medium text-slate-700 sm:grid-cols-2 sm:px-6 lg:grid-cols-4 lg:px-8">
      <p class="rounded-full bg-slate-100 px-4 py-2 text-center">NICEIC-ready standards</p>
      <p class="rounded-full bg-slate-100 px-4 py-2 text-center">Fast quote turnaround</p>
      <p class="rounded-full bg-slate-100 px-4 py-2 text-center">Tidy site policy</p>
      <p class="rounded-full bg-slate-100 px-4 py-2 text-center">Leicester-based team</p>
    </div>
  </section>

  <section id="services" class="bg-slate-50 py-20 md:py-24">
    <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
      <header class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-700">Core Services</p>
        <h2 class="mt-3 text-balance text-3xl font-bold tracking-tight text-slate-900 md:text-5xl">Expert support for homes and business premises.</h2>
        <p class="mt-4 text-lg text-slate-600">
          We focus on outcomes that matter: safety, clarity, and long-term reliability.
        </p>
      </header>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {
          services.map((service) => (
            <article class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:border-blue-300 hover:shadow-lg">
              <p class="text-xs font-semibold uppercase tracking-wide text-blue-700">{service.highlight}</p>
              <h3 class="text-xl font-semibold text-slate-900">{service.title}</h3>
              <p class="mt-3 text-slate-600">{service.detail}</p>
              <p class="mt-5 text-sm font-semibold text-slate-900 transition-colors group-hover:text-blue-700">Learn more -></p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="process" class="bg-white py-20 md:py-24">
    <div class="mx-auto grid w-full max-w-6xl gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
      <article>
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-700">Our Approach</p>
        <h2 class="mt-3 text-balance text-3xl font-bold text-slate-900 md:text-5xl">No guesswork. No surprises. Just a clean process.</h2>
        <p class="mt-5 text-lg text-slate-600">
          Most electrical stress comes from poor communication and vague pricing. We remove both.
        </p>
        <ul class="mt-7 space-y-3 text-slate-700">
          {
            benefits.map((item) => (
              <li class="flex items-start gap-3 rounded-lg bg-slate-100 px-4 py-3">
                <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-blue-600"></span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </article>

      <article class="rounded-2xl bg-slate-950 p-8 text-slate-200">
        <h3 class="text-xl font-bold text-white">How your project moves forward</h3>
        <div class="mt-6 space-y-4">
          {
            process.map((item) => (
              <div class="rounded-xl border border-slate-700 bg-slate-900 p-4">
                <p class="text-xs font-semibold tracking-[0.2em] text-amber-300">STEP {item.step}</p>
                <p class="mt-1 text-lg font-semibold text-white">{item.title}</p>
                <p class="mt-2 text-sm text-slate-300">{item.description}</p>
              </div>
            ))
          }
        </div>
      </article>
    </div>
  </section>

  <section id="why-us" class="bg-slate-50 py-20 md:py-24">
    <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl bg-gradient-to-r from-blue-900 to-blue-700 p-8 text-white md:p-12">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-100">Why Choose Tec Electrical</p>
        <h2 class="mt-3 max-w-3xl text-balance text-3xl font-bold md:text-5xl">
          We are the team clients call when they want quality without the drama.
        </h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          <div class="rounded-xl bg-white/12 p-5">
            <p class="text-3xl font-bold text-amber-300">98%</p>
            <p class="mt-2 text-sm text-blue-100">Jobs completed on first planned timeline</p>
          </div>
          <div class="rounded-xl bg-white/12 p-5">
            <p class="text-3xl font-bold text-amber-300">24h</p>
            <p class="mt-2 text-sm text-blue-100">Typical quotation response window</p>
          </div>
          <div class="rounded-xl bg-white/12 p-5">
            <p class="text-3xl font-bold text-amber-300">5★</p>
            <p class="mt-2 text-sm text-blue-100">Reputation built on clarity and care</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="bg-white py-20 md:py-24">
    <div class="mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8">
      <header class="text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-blue-700">FAQs</p>
        <h2 class="mt-3 text-3xl font-bold text-slate-900 md:text-4xl">Questions people ask before booking</h2>
      </header>
      <div class="mt-10 space-y-4">
        {
          faqs.map((faq) => (
            <details class="group rounded-xl border border-slate-200 bg-white p-5">
              <summary class="cursor-pointer list-none text-base font-semibold text-slate-900">
                {faq.question}
              </summary>
              <p class="mt-3 text-slate-600">{faq.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-slate-950 py-16 text-white">
    <div class="mx-auto flex w-full max-w-6xl flex-col items-start justify-between gap-6 px-4 sm:px-6 md:flex-row md:items-center lg:px-8">
      <div>
        <h2 class="text-3xl font-bold">Ready for electrical work that actually feels organised?</h2>
        <p class="mt-2 text-slate-200">Send your requirements and get a clear quote with practical next steps.</p>
      </div>
      <Button href="#contact">Get My Free Quote</Button>
    </div>
  </section>
</Layout>
