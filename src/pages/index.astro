---
import Button from "../components/ui/Button.astro";
import Layout from "../layouts/Layout.astro";

const services = [
  {
    title: "Domestic Rewires",
    detail: "Full and partial rewires for safer, future-ready homes.",
    highlight: "Home upgrades",
  },
  {
    title: "Fault Finding",
    detail: "Fast diagnosis and reliable repairs for urgent electrical faults.",
    highlight: "Emergency response",
  },
  {
    title: "Inspection and EICR",
    detail: "Certified testing and compliance reports for landlords and homeowners.",
    highlight: "Compliance ready",
  },
  {
    title: "Commercial Maintenance",
    detail: "Planned servicing and upgrades to keep operations uninterrupted.",
    highlight: "Business continuity",
  },
];

const benefits = [
  "Straightforward quote before any work begins",
  "Clear schedule and communication throughout",
  "Safe, regulation-ready workmanship every time",
  "Clean site policy and full final handover",
];

const process = [
  {
    step: "01",
    title: "Discovery",
    description: "A focused call to understand your issue, urgency, and target outcome.",
  },
  {
    step: "02",
    title: "Plan and Quote",
    description: "A transparent scope with timeline, options, and fixed pricing where possible.",
  },
  {
    step: "03",
    title: "Delivery and Certification",
    description: "Install, test, and sign-off with documentation and practical aftercare advice.",
  },
];

const featuredProject = {
  kicker: "Featured Project",
  client: "Stronghold Homes",
  name: "The Kilns",
  year: "2026",
  location: "Leicestershire",
  scope: "Full electrical installation across luxury new build homes",
  summary:
    "A signature collaboration with Stronghold Homes delivering complete first and second fix electrical works across this private development of luxury family homes. Every room was planned around statement lighting, layered scene control, and integrated detail.",
  highlights: [
    "Statement chandeliers across double-height voids and stairwells",
    "Concealed LED cove lighting and backlit feature walls in every reception room",
    "Kitchen pendant clusters, ceiling speakers, and full appliance circuits",
    "Wardrobe and dressing room LED profiles with bespoke shelf lighting",
    "External wall up/downlights, bollard runs, and night-time scene control",
  ],
  hero: {
    src: "/projects/the-kilns/exterior-sunset.png",
    alt: "The Kilns development by Stronghold Homes photographed at golden hour, showing a row of luxury family homes.",
  },
  video: {
    id: "P9JQ9nkGQ4U",
    title: "The Kilns development walkthrough by Stronghold Homes",
    label: "Development walkthrough",
    description:
      "Tour the finished development with Stronghold Homes and see the spaces where our lighting and electrical installation comes together.",
  },
  gallery: [
    {
      src: "/projects/the-kilns/kitchen.png",
      alt: "Open plan kitchen with pendant cluster, recessed downlights, ceiling speakers, and integrated appliances.",
      caption: "Kitchen lighting design",
    },
    {
      src: "/projects/the-kilns/lounge-shelves.png",
      alt: "Formal lounge with backlit display shelving, statement pendant, and bioethanol fireplace wall.",
      caption: "Backlit display joinery",
    },
    {
      src: "/projects/the-kilns/snug-panelled.png",
      alt: "Navy panelled snug with brass and glass chandelier and integrated LED-lit alcove shelving.",
      caption: "Panelled snug with feature lighting",
    },
    {
      src: "/projects/the-kilns/living-room-cove.png",
      alt: "Living room with cove perimeter lighting, ribbed alcove shelving, and a six-arm ceiling pendant.",
      caption: "Cove and alcove scenes",
    },
    {
      src: "/projects/the-kilns/snug-cove-lighting.png",
      alt: "Snug with chandelier, paired wall sconces, LED cove perimeter and flush ceiling speaker.",
      caption: "Layered media room scene",
    },
    {
      src: "/projects/the-kilns/bathroom-feature-tile.png",
      alt: "Bathroom with freestanding tub and dramatic backlit gold chevron tile feature wall.",
      caption: "Backlit bathroom feature wall",
    },
    {
      src: "/projects/the-kilns/arched-alcove.png",
      alt: "Marble step landing with arched, backlit wallpaper feature and overhead spot.",
      caption: "Arched feature niche",
    },
    {
      src: "/projects/the-kilns/exterior-front.png",
      alt: "Front elevation of The Kilns at dusk showing the family of homes across the development.",
      caption: "Front elevation",
    },
    {
      src: "/projects/the-kilns/driveway-dusk.png",
      alt: "Driveway at dusk with bollard pathway lighting and twin entrance wall sconces.",
      caption: "Driveway and exterior lighting",
    },
  ],
};

const faqs = [
  {
    question: "Can you take over an incomplete job from another contractor?",
    answer:
      "Yes. We assess existing work, flag safety concerns, and provide a clear plan to complete it properly.",
  },
  {
    question: "Do you offer appointments outside normal business hours?",
    answer:
      "Yes. We can schedule early, late, or weekend slots for commercial and time-sensitive projects.",
  },
  {
    question: "How do you present recommended work and costs?",
    answer:
      "We separate urgent repairs, recommended improvements, and optional upgrades so you can choose confidently.",
  },
  {
    question: "Will I get certification where required?",
    answer:
      "Absolutely. We provide all relevant certificates and handover notes on completion.",
  },
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Tec Electrical",
  description: "Domestic and commercial electrical services in Leicester and surrounding areas.",
  telephone: "+447000000000",
  email: "info@tecservicesltd.com",
  areaServed: "Leicester",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Leicester",
    addressCountry: "GB",
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "08:00",
      closes: "18:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Saturday"],
      opens: "09:00",
      closes: "14:00",
    },
  ],
  url: "https://tec.dotwall.co.uk/",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://tec.dotwall.co.uk/",
    },
  ],
};
---

<Layout
  pageTitle="Tec Electrical Leicester | Precision Electrical Services"
  pageDescription="Tec Electrical delivers precision domestic and commercial electrical services in Leicester with transparent planning, safe delivery, and certified outcomes."
  schemas={[localBusinessSchema, faqSchema, breadcrumbSchema]}
>
  <section class="relative overflow-hidden bg-slate-950 py-24 text-white md:py-28">
    <div class="absolute inset-0 opacity-50 [background:radial-gradient(circle_at_10%_20%,rgba(56,189,248,0.35),transparent_42%),radial-gradient(circle_at_90%_0%,rgba(251,191,36,0.3),transparent_34%),linear-gradient(120deg,#020617_0%,#0f172a_48%,#1e3a8a_100%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.06)_1px,transparent_1px)] bg-[size:52px_52px] [mask-image:linear-gradient(to_bottom,black,transparent)]"></div>
    <div class="relative mx-auto grid w-full max-w-6xl gap-12 px-4 sm:px-6 lg:grid-cols-[1.2fr_0.8fr] lg:px-8">
      <article class="max-w-2xl">
        <p class="section-kicker text-slate-200" data-step="01">Main Hub</p>
        <h1 class="mt-5 text-balance text-5xl font-black uppercase leading-[0.95] md:text-7xl">
          We power spaces
          <span class="block text-amber-300">with precision.</span>
        </h1>
        <p class="mt-6 max-w-xl text-base leading-relaxed text-slate-200 md:text-lg">
          Tec Electrical delivers industrial-grade standards for domestic and commercial projects. You get accuracy,
          transparency, and delivery that protects your property from day one.
        </p>
        <div class="mt-9 flex flex-wrap gap-4">
          <Button href="#contact">Start Collaboration</Button>
          <Button href="#services" variant="secondary">Explore Services</Button>
        </div>
      </article>
      <article class="border border-slate-700 bg-slate-900/65 p-6 backdrop-blur">
        <p class="text-xs font-bold uppercase tracking-[0.16em] text-blue-200">Active Operations</p>
        <div class="mt-5 space-y-4">
          <div class="border border-slate-700 bg-slate-900 p-4">
            <p class="text-xs font-bold uppercase tracking-[0.12em] text-amber-300">Emergency Callout</p>
            <p class="mt-2 text-lg font-bold">Consumer unit fault isolation</p>
            <p class="mt-2 text-sm text-slate-300">Restored safely with testing and compliance checks.</p>
          </div>
          <div class="border border-slate-700 bg-slate-900 p-4">
            <p class="text-xs font-bold uppercase tracking-[0.12em] text-amber-300">Commercial Upgrade</p>
            <p class="mt-2 text-lg font-bold">Retail lighting efficiency retrofit</p>
            <p class="mt-2 text-sm text-slate-300">Lower power usage with brighter and cleaner lighting output.</p>
          </div>
          <div class="border border-slate-700 bg-slate-900 p-4">
            <p class="text-xs font-bold uppercase tracking-[0.12em] text-amber-300">Compliance Package</p>
            <p class="mt-2 text-lg font-bold">Landlord EICR and remedial plan</p>
            <p class="mt-2 text-sm text-slate-300">Clear reporting and priority fixes for fast compliance.</p>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="bg-white py-10">
    <div class="mx-auto grid w-full max-w-6xl gap-4 px-4 sm:grid-cols-2 sm:px-6 lg:grid-cols-4 lg:px-8">
      <p class="border border-slate-200 px-4 py-3 text-center text-xs font-bold uppercase tracking-[0.12em] text-slate-700">Domestic and commercial</p>
      <p class="border border-slate-200 px-4 py-3 text-center text-xs font-bold uppercase tracking-[0.12em] text-slate-700">Compliance-led delivery</p>
      <p class="border border-slate-200 px-4 py-3 text-center text-xs font-bold uppercase tracking-[0.12em] text-slate-700">Fast quote turnaround</p>
      <p class="border border-slate-200 px-4 py-3 text-center text-xs font-bold uppercase tracking-[0.12em] text-slate-700">Leicester-based team</p>
    </div>
  </section>

  <section id="why-us" class="bg-slate-50 py-20 md:py-24">
    <div class="mx-auto grid w-full max-w-6xl gap-8 px-4 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:px-8">
      <article class="border border-slate-200 bg-white p-7 md:p-10">
        <p class="section-kicker text-slate-700" data-step="02">About Us</p>
        <h2 class="mt-4 text-3xl font-black uppercase leading-tight text-slate-900 md:text-4xl">We plan to remove risk before work begins.</h2>
        <p class="mt-4 text-slate-600">
          Most electrical issues are manageable when handled with structure. We scope carefully, price transparently, and
          execute to a high technical standard.
        </p>
      </article>
      <article class="border border-slate-200 bg-white p-7 md:p-10">
        <ul class="grid gap-4 md:grid-cols-2">
          {
            benefits.map((item) => (
              <li class="border border-slate-200 bg-slate-50 p-4 text-sm font-medium text-slate-800">{item}</li>
            ))
          }
        </ul>
      </article>
    </div>
  </section>

  <section id="services" class="bg-white py-20 md:py-24">
    <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
      <header class="max-w-4xl">
        <p class="section-kicker text-slate-700" data-step="03">Business Segments</p>
        <h2 class="mt-4 text-balance text-3xl font-black uppercase leading-tight text-slate-900 md:text-5xl">
          Core electrical services across critical environments.
        </h2>
      </header>

      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {
          services.map((service) => (
            <article class="group border border-slate-200 bg-slate-50 p-6 transition-all duration-200 hover:-translate-y-1 hover:border-slate-900 hover:bg-white">
              <p class="text-xs font-bold uppercase tracking-[0.12em] text-blue-700">{service.highlight}</p>
              <h3 class="mt-2 text-2xl font-black uppercase leading-tight text-slate-900">{service.title}</h3>
              <p class="mt-3 text-slate-600">{service.detail}</p>
              <p class="mt-6 text-xs font-bold uppercase tracking-[0.12em] text-slate-900 transition-colors group-hover:text-blue-700">Read Details -></p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="projects" class="bg-slate-50 py-20 md:py-28">
    <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
      <header class="grid gap-6 md:grid-cols-[1.1fr_0.9fr] md:items-end">
        <div>
          <p class="section-kicker text-slate-700" data-step="04">{featuredProject.kicker}</p>
          <h2 class="mt-4 text-balance text-3xl font-black uppercase leading-tight text-slate-900 md:text-5xl">
            {featuredProject.name}
            <span class="block text-blue-700">with {featuredProject.client}</span>
          </h2>
        </div>
        <p class="text-base leading-relaxed text-slate-600 md:text-lg">
          {featuredProject.summary}
        </p>
      </header>

      <dl class="mt-10 grid gap-px overflow-hidden border border-slate-200 bg-slate-200 md:grid-cols-4">
        <div class="bg-white p-5">
          <dt class="text-xs font-bold uppercase tracking-[0.14em] text-slate-500">Client</dt>
          <dd class="mt-2 text-sm font-bold uppercase tracking-wide text-slate-900">{featuredProject.client}</dd>
        </div>
        <div class="bg-white p-5">
          <dt class="text-xs font-bold uppercase tracking-[0.14em] text-slate-500">Project</dt>
          <dd class="mt-2 text-sm font-bold uppercase tracking-wide text-slate-900">{featuredProject.name}</dd>
        </div>
        <div class="bg-white p-5">
          <dt class="text-xs font-bold uppercase tracking-[0.14em] text-slate-500">Location</dt>
          <dd class="mt-2 text-sm font-bold uppercase tracking-wide text-slate-900">{featuredProject.location}</dd>
        </div>
        <div class="bg-white p-5">
          <dt class="text-xs font-bold uppercase tracking-[0.14em] text-slate-500">Year</dt>
          <dd class="mt-2 text-sm font-bold uppercase tracking-wide text-slate-900">{featuredProject.year}</dd>
        </div>
      </dl>

      <figure class="relative mt-10 overflow-hidden border border-slate-200 bg-slate-900">
        <img
          src={featuredProject.hero.src}
          alt={featuredProject.hero.alt}
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
        <figcaption class="absolute bottom-0 left-0 right-0 flex flex-wrap items-end justify-between gap-3 bg-gradient-to-t from-black/75 via-black/30 to-transparent px-5 py-5 text-white">
          <span class="text-xs font-bold uppercase tracking-[0.18em] text-amber-300">Featured Build</span>
          <span class="text-xs font-medium uppercase tracking-[0.12em] text-slate-100">{featuredProject.scope}</span>
        </figcaption>
      </figure>

      <div class="mt-10 grid gap-5 lg:grid-cols-[0.95fr_1.05fr] lg:items-stretch">
        <article class="flex flex-col justify-between border border-slate-200 bg-white p-6 md:p-8">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.14em] text-blue-700">{featuredProject.video.label}</p>
            <h3 class="mt-3 text-2xl font-black uppercase leading-tight text-slate-900">
              See the development in motion.
            </h3>
            <p class="mt-4 text-sm leading-relaxed text-slate-600 md:text-base">
              {featuredProject.video.description}
            </p>
          </div>
          <a
            href={`https://www.youtube.com/watch?v=${featuredProject.video.id}`}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 self-start text-xs font-bold uppercase tracking-[0.14em] text-slate-900 transition-colors hover:text-blue-700"
          >
            Watch on YouTube
            <span aria-hidden="true">-></span>
          </a>
        </article>

        <div class="relative aspect-video w-full overflow-hidden border border-slate-200 bg-slate-900 shadow-sm">
          <iframe
            class="absolute inset-0 h-full w-full"
            src={`https://www.youtube-nocookie.com/embed/${featuredProject.video.id}?rel=0`}
            title={featuredProject.video.title}
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <div class="mt-10 grid gap-5 lg:grid-cols-[1.05fr_0.95fr]">
        <article class="border border-slate-200 bg-white p-6 md:p-8">
          <p class="text-xs font-bold uppercase tracking-[0.14em] text-blue-700">Scope of works</p>
          <h3 class="mt-3 text-2xl font-black uppercase leading-tight text-slate-900">Lighting designed room by room.</h3>
          <ul class="mt-5 space-y-3">
            {
              featuredProject.highlights.map((item) => (
                <li class="flex gap-3 border-l-2 border-amber-300 bg-slate-50 px-4 py-3 text-sm text-slate-700">
                  <span class="text-xs font-bold uppercase tracking-[0.14em] text-blue-700">+</span>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
        </article>

        <article class="grid grid-cols-2 gap-3">
          {
            featuredProject.gallery.slice(0, 4).map((image) => (
              <figure class="group relative overflow-hidden border border-slate-200 bg-slate-100">
                <img
                  src={image.src}
                  alt={image.alt}
                  loading="lazy"
                  decoding="async"
                  class="aspect-[4/5] h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                />
                <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent p-3 text-[11px] font-bold uppercase tracking-[0.12em] text-white">
                  {image.caption}
                </figcaption>
              </figure>
            ))
          }
        </article>
      </div>

      <div class="mt-5 grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
        {
          featuredProject.gallery.slice(4).map((image) => (
            <figure class="group relative overflow-hidden border border-slate-200 bg-slate-100">
              <img
                src={image.src}
                alt={image.alt}
                loading="lazy"
                decoding="async"
                class="aspect-[3/4] h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent p-3 text-[11px] font-bold uppercase tracking-[0.12em] text-white">
                {image.caption}
              </figcaption>
            </figure>
          ))
        }
      </div>

      <div class="mt-10 flex flex-wrap items-center justify-between gap-4 border border-slate-200 bg-white p-5">
        <p class="text-sm text-slate-700">
          Planning a development or self-build of your own? We work end-to-end with builders, designers, and homeowners.
        </p>
        <Button href="#contact" variant="secondary">Discuss Your Project</Button>
      </div>
    </div>
  </section>

  <section id="process" class="bg-slate-900 py-20 text-white md:py-24">
    <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
      <header class="max-w-4xl">
        <p class="section-kicker text-slate-200" data-step="05">Delivery Process</p>
        <h2 class="mt-4 text-balance text-3xl font-black uppercase leading-tight md:text-5xl">From first call to final sign-off.</h2>
      </header>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {
          process.map((item) => (
            <article class="border border-slate-700 bg-slate-950 p-6">
              <p class="text-xs font-bold tracking-[0.18em] text-amber-300">STEP {item.step}</p>
              <h3 class="mt-3 text-2xl font-black uppercase">{item.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-slate-300">{item.description}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-slate-100 py-16">
    <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-4 md:grid-cols-3">
        <div class="border border-slate-200 bg-white p-6">
          <p class="text-4xl font-black text-slate-900">24h</p>
          <p class="mt-2 text-xs font-bold uppercase tracking-[0.12em] text-slate-600">Typical quote response</p>
        </div>
        <div class="border border-slate-200 bg-white p-6">
          <p class="text-4xl font-black text-slate-900">98%</p>
          <p class="mt-2 text-xs font-bold uppercase tracking-[0.12em] text-slate-600">On-schedule completion</p>
        </div>
        <div class="border border-slate-200 bg-white p-6">
          <p class="text-4xl font-black text-slate-900">5★</p>
          <p class="mt-2 text-xs font-bold uppercase tracking-[0.12em] text-slate-600">Client reputation score</p>
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="bg-white py-20 md:py-24">
    <div class="mx-auto w-full max-w-4xl px-4 sm:px-6 lg:px-8">
      <header class="text-center">
        <p class="section-kicker justify-center text-slate-700" data-step="06">Frequently Asked</p>
        <h2 class="mt-3 text-balance text-3xl font-black uppercase text-slate-900 md:text-5xl">Common client questions before we begin.</h2>
      </header>
      <div class="mt-10 space-y-4">
        {
          faqs.map((faq) => (
            <details class="group border border-slate-200 bg-slate-50 p-5">
              <summary class="cursor-pointer list-none text-base font-bold text-slate-900">
                {faq.question}
              </summary>
              <p class="mt-3 text-slate-600">{faq.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-slate-950 py-16 text-white">
    <div class="mx-auto flex w-full max-w-6xl flex-col items-start justify-between gap-6 px-4 sm:px-6 md:flex-row md:items-center lg:px-8">
      <div>
        <h2 class="text-3xl font-black uppercase leading-tight">Build your project with a team that delivers with intent.</h2>
        <p class="mt-2 text-slate-200">Share your requirements and get a structured plan with a transparent quote.</p>
      </div>
      <Button href="#contact">Contact Us</Button>
    </div>
  </section>
</Layout>
