---
import Button from "../ui/Button.astro";

const links = [
  { href: "#services", label: "Services" },
  { href: "#why-us", label: "Why Choose Us" },
  { href: "#faq", label: "FAQs" },
  { href: "#contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/95 backdrop-blur">
  <div class="border-b border-slate-200 bg-slate-950 text-slate-200">
    <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-4 py-2 text-xs tracking-wide sm:px-6 lg:px-8">
      <p class="font-medium uppercase">Leicester Electrical Specialists</p>
      <a href="tel:+447000000000" class="font-semibold text-amber-300 hover:text-amber-200">
        +44 7000 000000
      </a>
    </div>
  </div>
  <div class="mx-auto flex h-16 w-full max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="text-lg font-black uppercase tracking-[0.08em] text-slate-900">
      Tec <span class="text-blue-700">Electrical</span>
    </a>

    <nav aria-label="Primary navigation" class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <a href={link.href} class="text-xs font-bold uppercase tracking-[0.12em] text-slate-700 transition-colors hover:text-blue-700">
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:block">
      <Button href="#contact">Get My Free Quote</Button>
    </div>

    <details class="relative md:hidden">
      <summary class="list-none border border-slate-300 px-3 py-2 text-xs font-bold uppercase tracking-[0.12em] text-slate-800">
        Menu
      </summary>
      <nav
        aria-label="Mobile navigation"
        class="absolute right-0 mt-2 w-64 rounded-xl border border-slate-200 bg-white p-4 shadow-xl"
      >
        <ul class="space-y-3">
          {
            links.map((link) => (
              <li>
                <a href={link.href} class="block text-sm font-medium text-slate-700 hover:text-blue-700">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="mt-4">
          <Button href="#contact" fullWidth={true}>
            Get My Free Quote
          </Button>
        </div>
      </nav>
    </details>
  </div>
</header>
