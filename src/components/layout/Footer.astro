---
import ContactForm from "../ContactForm.astro";
---

<footer id="contact" class="bg-slate-950 py-14 text-slate-200">
  <div class="mx-auto grid w-full max-w-6xl gap-10 border-b border-slate-800 px-4 pb-10 sm:px-6 lg:grid-cols-2 lg:gap-12 lg:px-8">
    <section class="space-y-8">
      <div>
        <p class="section-kicker text-slate-300" data-step="06">Contact Hub</p>
        <h2 class="mt-3 text-xl font-black uppercase tracking-[0.08em] text-white">Tec Electrical</h2>
        <p class="mt-4 text-sm leading-relaxed text-slate-300">
          Reliable domestic and commercial electrical services, delivered with clean workmanship and clear
          communication.
        </p>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2">
        <section>
          <h3 class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-100">Contact</h3>
          <ul class="mt-4 space-y-2 text-sm text-slate-300">
            <li><a class="hover:text-white" href="tel:+447000000000">+44 7000 000000</a></li>
            <li>
              <a class="hover:text-white" href="mailto:info@tecservicesltd.com">info@tecservicesltd.com</a>
            </li>
            <li>Leicester and surrounding areas</li>
          </ul>
        </section>

        <section>
          <h3 class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-100">Opening Hours</h3>
          <ul class="mt-4 space-y-2 text-sm text-slate-300">
            <li>Mon-Fri: 08:00-18:00</li>
            <li>Sat: 09:00-14:00</li>
            <li>Emergency callouts available</li>
          </ul>
        </section>
      </div>
    </section>

    <section class="border border-slate-800 bg-slate-900/50 p-6 sm:p-8">
      <h3 class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-100">Get a free quote</h3>
      <p class="mt-2 text-sm text-slate-400">
        Send your details and we will reply to the email address you provide.
      </p>
      <ContactForm />
    </section>
  </div>
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-3 px-4 pt-6 text-xs uppercase tracking-[0.12em] text-slate-400 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
    <p>Infrastructure-grade electrical delivery</p>
    <p>Serving Leicester and surrounding areas</p>
  </div>
</footer>
