---
interface Props {
  href?: string;
  variant?: "primary" | "secondary";
  fullWidth?: boolean;
}

const { href, variant = "primary", fullWidth = false } = Astro.props;
const classes = `inline-flex items-center justify-center border px-6 py-3 text-xs font-bold uppercase tracking-[0.14em] transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 ${
  variant === "primary"
    ? "border-amber-300 bg-amber-300 text-slate-950 hover:bg-amber-200 hover:border-amber-200 focus-visible:outline-amber-300"
    : "border-slate-900 bg-transparent text-slate-900 hover:bg-slate-900 hover:text-white focus-visible:outline-slate-900"
} ${fullWidth ? "w-full" : ""}`;
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type="button" class={classes}>
      <slot />
    </button>
  )
}
